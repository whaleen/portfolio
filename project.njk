---
pagination:
  data: projects
  size: 1
  alias: project
permalink: "projects/{{ project.org }}/{{ project.name | slugify }}/"
layout: layouts/base.njk
---

<div class="mw7 center pa3 pa4-ns">
    <a href="/" class="f6 fw5 color-vesper-muted no-underline hover-vesper-accent">← Back to Projects</a>
    
    <header class="flex flex-column flex-row-ns justify-between items-start items-center-ns mv4">
        <h1 class="f2 fw8 ma0 mb2 mb0-ns color-vesper-fg">{{ project.name }}</h1>
        <div class="flex gap3 f6 fw6">
            <a href="{{ project.github.url }}" target="_blank" class="no-underline color-vesper-accent hover-vesper-fg mr3 bb border-vesper">GitHub</a>
            {%- if project.github.homepage -%}
            <a href="{{ project.github.homepage }}" target="_blank" class="no-underline color-vesper-accent hover-vesper-fg bb border-vesper">Live Site</a>
            {%- endif -%}
        </div>
    </header>

    {%- if project.github.socialPreviewUrl -%}
    <div class="w-100 mb4 border-vesper ba br3 overflow-hidden">
        <img src="{{ project.github.socialPreviewUrl }}" alt="{{ project.name }} preview" class="w-100 h-auto db">
    </div>
    {%- endif -%}

    <div class="project-content">
        <p class="f3 lh-copy color-vesper-fg mv4">
            {{ project.github.description | default("No description available.") }}
        </p>

        <div class="flex flex-row justify-around bt bb border-vesper pv4 mv5 tc">
            <div class="flex flex-column items-center">
                <span class="f7 ttu tracked color-vesper-muted mb1">Language</span>
                <span class="f3 fw7 color-vesper-fg">{{ project.github.language | default("N/A") }}</span>
            </div>
            <div class="flex flex-column items-center">
                <span class="f7 ttu tracked color-vesper-muted mb1">Last Pushed</span>
                <span class="f3 fw7 color-vesper-fg">{{ project.github.pushedAt | date }}</span>
            </div>
        </div>

        {%- if project.github.topics.length > 0 -%}
        <div class="mv4">
            <div class="flex flex-wrap gap2 mt2">
                {%- for topic in project.github.topics -%}
                <span class="f7 fw6 ph2 pv1 br2 bg-vesper-card color-vesper-fg mr1 mb1">{{ topic }}</span>
                {%- endfor -%}
            </div>
        </div>
        {%- endif -%}

        {%- set readme = project.github.readme -%}
        {%- if readme -%}
        <div class="markdown-body mt5 bt border-vesper pt5">
            {{ readme | markdown | safe }}
        </div>
        {%- endif -%}
    </div>
</div>
