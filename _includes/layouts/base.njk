<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title | default("Portfolio") }}</title>
    <link rel="stylesheet" href="https://unpkg.com/tachyons@4.12.0/css/tachyons.min.css">
    <style>
        :root {
            --bg: #101010;
            --fg: #ffffff;
            --accent: #FFC799;
            --muted: #A0A0A0;
            --card-bg: #181818;
            --border: #333333;
            --tag-bg: #282828;
        }
        body {
            background-color: var(--bg);
            color: var(--fg);
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        }
        /* Custom Vesper Utilities */
        .color-vesper-bg { background-color: var(--bg); }
        .color-vesper-fg { color: var(--fg); }
        .color-vesper-accent { color: var(--accent); }
        .color-vesper-muted { color: var(--muted); }
        .bg-vesper-card { background-color: var(--card-bg); }
        .border-vesper { border-color: var(--border); }
        .hover-vesper-accent:hover { color: var(--accent); }
        .hover-vesper-bg-accent:hover { background-color: var(--accent); color: var(--bg); }
        
        /* Markdown overrides to play nice with Vesper */
        .markdown-body h1, .markdown-body h2, .markdown-body h3 { color: var(--accent); margin-top: 2rem; margin-bottom: 1rem; }
        .markdown-body pre { background: var(--card-bg); padding: 1rem; border-radius: 4px; border: 1px solid var(--border); overflow-x: auto; }
        .markdown-body code { font-family: monospace; background: var(--tag-bg); padding: 0.2rem 0.4rem; border-radius: 3px; }
        .markdown-body a { color: var(--accent); text-decoration: none; }
        .markdown-body a:hover { text-decoration: underline; }
        .markdown-body img { max-width: 100%; height: auto; border-radius: 4px; }
        .markdown-body blockquote { border-left: 4px solid var(--border); padding-left: 1rem; color: var(--muted); margin-left: 0; }
    </style>
</head>
<body class="w-100 sans-serif">
    <header class="mw8 center pa4 pt5 pb4">
        <h1 class="f1 fw8 ma0 mb2"><a href="/" class="no-underline color-vesper-fg hover-vesper-accent">Josh Vaage</a></h1>
        <p class="f4 color-vesper-muted ma0">Software Engineer. Open Source & Projects.</p>
    </header>
    
    <main class="mw8 center pa4">
        {{ content | safe }}
    </main>

    <footer class="mw8 center pa4 pt5 pb5">
        <p class="f6 color-vesper-muted bt border-vesper pt4">
            Built with 11ty. Updated: {{ "now" | date }} | <a href="/colophon" class="no-underline color-vesper-accent dim">Colophon</a>
        </p>
    </footer>
</body>
</html>
